# Скопируйте на сервер как /opt/benzinopedia-backend/.env и задайте реальные значения.
# Пароль генерируется при деплое — см. server/deploy/README-VPS.md

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=benzinopedia
MYSQL_USER=benzinopedia
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD

SERVER_PORT=8082
CORS_ALLOWED_ORIGINS=https://benzinopedia.ru,http://benzinopedia.ru,https://www.benzinopedia.ru,http://www.benzinopedia.ru,https://oleg-rakitin.github.io,http://localhost:5500
